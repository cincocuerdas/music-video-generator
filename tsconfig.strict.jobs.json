{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "strictNullChecks": true
  },
  "include": [
    "src/modules/jobs/**/*.ts",
    "src/modules/queue/**/*.ts",
    "src/modules/events/**/*.ts",
    "src/modules/projects/dto/**/*.ts",
    "src/modules/jobs/dto/**/*.ts",
    "src/common/services/**/*.ts",
    "src/common/constants/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "client"
  ]
}

