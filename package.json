{
  "name": "music-video-generator-api",
  "version": "0.1.0",
  "description": "Backend API for Music Video Generator",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node --max-old-space-size=4096 dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:types:jobs-strict": "tsc --project tsconfig.strict.jobs.json --pretty false",
    "test:types:backend-strict": "tsc --project tsconfig.strict.backend.json --pretty false",
    "test:python-runner-contract": "jest python-runner.integration.spec.ts --runInBand",
    "test:webhook-security": "jest webhook-security.util.spec.ts --runInBand",
    "test:health-ops": "jest health.service.spec.ts --runInBand",
    "test:envelope-contract": "npm run test:ops:prepare && node scripts/dev-tools/test_envelope_contract.js",
    "test:projects-optimization": "jest projects.service.spec.ts --runInBand",
    "test:auth-service": "jest auth.service.spec.ts --runInBand",
    "test:jobs-handoff": "jest jobs.service.advance-pipeline.spec.ts --runInBand",
    "test:processors-smoke": "jest processors.smoke.spec.ts --runInBand",
    "test:processors-failures": "jest processors.failure.spec.ts --runInBand",
    "test:dead-letter": "jest dead-letter.processor.spec.ts --runInBand",
    "test:pipeline-script-contract": "node scripts/dev-tools/test_pipeline_script_contract.js",
    "test:redis-client": "jest redis-client.service.spec.ts --runInBand",
    "test:prod-guards": "node scripts/dev-tools/test_prod_guards.js",
    "test:repo-hygiene": "node scripts/dev-tools/test_repo_hygiene.js",
    "test:artifact-hygiene": "node scripts/dev-tools/test_artifact_hygiene.js",
    "test:secret-hygiene": "node scripts/dev-tools/test_secret_hygiene.js",
    "test:bullmq-retries": "node scripts/dev-tools/test_bullmq_retries.js",
    "test:auth-throttling": "npm run test:ops:prepare && node scripts/dev-tools/test_auth_throttling.js",
    "test:pipeline-status": "npm run test:ops:prepare && node scripts/dev-tools/test_pipeline_status.js",
    "test:external-chaos": "npm run test:ops:prepare && node scripts/dev-tools/test_external_chaos.js",
    "test:external-latency-chaos": "npm run test:ops:prepare && node scripts/dev-tools/test_external_latency_chaos.js",
    "test:latency-slo-alerts": "npm run test:ops:prepare && node scripts/dev-tools/test_latency_slo_alerts.js",
    "test:health-webhook-receiver": "npm run test:ops:prepare && node scripts/dev-tools/test_health_webhook_receiver.js",
    "test:health-alert-webhook": "npm run test:ops:prepare && node scripts/dev-tools/test_health_alert_webhook.js",
    "test:feedback-optimization": "npm run test:ops:prepare && node scripts/dev-tools/test_feedback_optimization.js",
    "test:resilience": "npm run test:ops:prepare && node scripts/dev-tools/test_resilience.js",
    "test:throttling": "npm run test:ops:prepare && node scripts/dev-tools/test_throttling.js",
    "test:e2e-pipeline": "node scripts/dev-tools/test_e2e_pipeline_playwright.js",
    "test:pre-commit-guard": "node scripts/dev-tools/pre_commit_guard.js",
    "test:pre-push-guard": "node scripts/dev-tools/pre_push_guard.js",
    "test:pre-push-full": "node scripts/dev-tools/pre_push_full_guard.js",
    "bench:image-generation-concurrency": "node scripts/dev-tools/benchmark_generate_images_concurrency.js",
    "bench:image-generation-history": "node scripts/dev-tools/benchmark_update_history.js",
    "bench:image-generation-slo": "node scripts/dev-tools/benchmark_assert_slo.js",
    "bench:image-generation-full": "npm run bench:image-generation-concurrency && npm run bench:image-generation-history && npm run bench:image-generation-slo",
    "smoke:real-baseline": "node scripts/dev-tools/smoke_baseline_real.js",
    "test:python-units": "cd scripts && python -m unittest tests.test_workflow_loading tests.test_interrupt_comfyui tests.test_whisper_timeout -v",
    "drill:fire": "node scripts/dev-tools/run_fire_drill.js",
    "ops:cleanup": "node scripts/dev-tools/cleanup_retention.js",
    "test:ops:prepare": "node scripts/dev-tools/test_ops_prepare.js",
    "test:ops": "npm run test:ops:prepare && npm run test:repo-hygiene && npm run test:artifact-hygiene && npm run test:secret-hygiene && npm run test:python-runner-contract && npm run test:webhook-security && npm run test:health-ops && npm run test:envelope-contract && npm run test:projects-optimization && npm run test:auth-service && npm run test:jobs-handoff && npm run test:processors-smoke && npm run test:processors-failures && npm run test:dead-letter && npm run test:pipeline-script-contract && npm run test:redis-client && npm run test:prod-guards && npm run test:bullmq-retries && npm run test:auth-throttling && npm run test:pipeline-status && npm run test:external-chaos && npm run test:external-latency-chaos && npm run test:latency-slo-alerts && npm run test:health-webhook-receiver && npm run test:health-alert-webhook && npm run test:feedback-optimization && npm run test:resilience && npm run test:throttling",
    "hooks:install": "node scripts/dev-tools/install_git_hooks.js",
    "backend:up": "node scripts/dev-tools/backend_runtime.js up",
    "backend:down": "node scripts/dev-tools/backend_runtime.js down",
    "backend:status": "node scripts/dev-tools/backend_runtime.js status",
    "summarize:source": "node scripts/dev-tools/summarize_source.js"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/common": "^10.4.1",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.1",
    "@nestjs/platform-express": "^10.4.1",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.3.0",
    "@nestjs/websockets": "^11.1.15",
    "@prisma/client": "^5.19.0",
    "@sentry/node": "^9.0.0",
    "axios": "^1.13.2",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "clsx": "^2.1.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.562.0",
    "react-router-dom": "^7.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/schematics": "^10.1.3",
    "@steipete/summarize": "^0.11.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.5.0",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^30.2.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "prettier": "^3.3.3",
    "prisma": "^5.19.0",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
