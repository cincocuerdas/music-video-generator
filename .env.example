# Application
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
CORS_ORIGIN=http://localhost:5173
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_DEBUG=false
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
THROTTLE_AUTH_DEV_TOKEN_LIMIT=10
THROTTLE_AUTH_LOGIN_DEV_LIMIT=10
THROTTLE_AUTH_REFRESH_LIMIT=30
THROTTLE_AUTH_LOGOUT_LIMIT=60
THROTTLE_AUTH_ME_LIMIT=120
THROTTLE_PROJECTS_CREATE_LIMIT=20
THROTTLE_PROJECTS_GENERATE_LIMIT=8
THROTTLE_PROJECTS_CANCEL_LIMIT=15
THROTTLE_PROJECTS_FEEDBACK_LIMIT=45
THROTTLE_PROJECTS_FEEDBACK_STATS_LIMIT=30
THROTTLE_PROJECTS_PROMPT_OPTIMIZATION_LIMIT=30
THROTTLE_PROJECTS_LIVE_SIGNAL_LIMIT=60
THROTTLE_JOBS_CREATE_LIMIT=20
THROTTLE_JOBS_UPDATE_LIMIT=30
THROTTLE_JOBS_DELETE_LIMIT=20
THROTTLE_JOBS_PIPELINE_START_LIMIT=8
THROTTLE_JOBS_PIPELINE_CANCEL_LIMIT=15
THROTTLE_HEALTH_OPS_LIMIT=30
THROTTLE_HEALTH_OPS_DEGRADED_LIMIT=30
THROTTLE_WEBHOOKS_HEALTH_ALERT_LIMIT=60
FEEDBACK_DEDUPE_WINDOW_MS=5000
PGVECTOR_ANN_CANDIDATE_LIMIT=250
PGVECTOR_SIMILARITY_LIMIT=10
HEALTH_OPS_MAX_INSPECT_JOBS=500
HEALTH_DEGRADED_ALERT_WARN_PCT=5
HEALTH_DEGRADED_ALERT_CRITICAL_PCT=20
HEALTH_DEGRADED_ALERT_MIN_COMPLETED_WINDOW=5
HEALTH_DEGRADED_ALERT_COOLDOWN_MS=900000
HEALTH_ALERT_WEBHOOK_URL=
HEALTH_ALERT_WEBHOOK_TIMEOUT_MS=5000
HEALTH_ALERT_WEBHOOK_SECRET=
HEALTH_WEBHOOK_RECEIVER_SECRET=
HEALTH_WEBHOOK_RECEIVER_MAX_SKEW_SEC=300
HEALTH_SLO_P95_WARN_MS=120000
HEALTH_SLO_P95_CRITICAL_MS=300000
HEALTH_SLO_P95_MIN_COMPLETED_24H=3
DEV_USER_ID=00000000-0000-4000-8000-000000000001
JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me_refresh
JWT_REFRESH_TOKEN_PEPPER=change_me_pepper
JWT_USER_ID_CLAIM=sub
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d
ALLOW_DEV_AUTH_BYPASS=false

# Database / Queue
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/musicvideo
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_RETRY_BASE_DELAY_MS=250
REDIS_RETRY_MAX_DELAY_MS=5000
REDIS_MAX_RETRIES_PER_REQUEST=null
REDIS_ENABLE_OFFLINE_QUEUE=true
QUEUE_DEFAULT_JOB_ATTEMPTS=2
QUEUE_DEFAULT_JOB_BACKOFF_MS=10000
QUEUE_DEFAULT_REMOVE_ON_COMPLETE=200
QUEUE_DEFAULT_REMOVE_ON_FAIL=500
JOB_RETRY_ATTEMPTS_YOUTUBE_DOWNLOAD=2
JOB_RETRY_DELAY_MS_YOUTUBE_DOWNLOAD=15000
JOB_RETRY_ATTEMPTS_TRANSCRIPTION=2
JOB_RETRY_DELAY_MS_TRANSCRIPTION=20000
JOB_RETRY_ATTEMPTS_ANALYZE_LYRICS=3
JOB_RETRY_DELAY_MS_ANALYZE_LYRICS=10000
JOB_RETRY_ATTEMPTS_GENERATE_IMAGES=3
JOB_RETRY_DELAY_MS_GENERATE_IMAGES=15000
JOB_RETRY_ATTEMPTS_RENDER_VIDEO=2
JOB_RETRY_DELAY_MS_RENDER_VIDEO=20000
JOB_RETRY_ATTEMPTS_TRAIN_LORA=2
JOB_RETRY_DELAY_MS_TRAIN_LORA=60000
JOB_STALE_WATCHDOG_ENABLED=true
JOB_STALE_WATCHDOG_INTERVAL_MS=60000
JOB_STALE_TIMEOUT_MS=900000
JOB_STALE_WATCHDOG_BATCH_SIZE=20

# Pipeline behavior
USE_MOCK_PROCESSORS=true
PYTHON_PATH=python
PYTHON_SCRIPT_TIMEOUT_MS=
FFMPEG_PATH=ffmpeg
FFMPEG_BIN=
FFMPEG_EXTRA_PATHS=

# AI providers
LLM_PROVIDER=gemini
GEMINI_API_KEY=replace_me
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODELS_TIMEOUT_SEC=10
GEMINI_REQUEST_TIMEOUT_SEC=45
GEMINI_REQUEST_RETRIES=2
REPLICATE_API_TOKEN=replace_me
IMAGE_PROVIDER=comfyui

# ComfyUI
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_CHECKPOINT=epicrealismXL_vxviiCrystalclear.safetensors
COMFYUI_HAND_LORA_MODE=auto
# Legacy compatibility (prefer COMFYUI_HAND_LORA_MODE)
COMFYUI_DISABLE_HAND_LORA=false
PLACEHOLDER_IMAGE_BASE_URL=https://placehold.co
MOCK_VIDEO_URL=

# Frontend (Vite dev proxy)
VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:3000
VITE_API_PROXY_TARGET=
VITE_OUTPUT_PROXY_TARGET=
VITE_SOCKET_PROXY_TARGET=

# Optional test scripts
API_BASE_URL=http://localhost:3000/api/v1

# Whisper
WHISPER_MODEL=large-v3
WHISPER_INITIAL_PROMPT=
SKIP_YOUTUBE_SUBS=
PYTHON_LEGACY_PROGRESS_STDERR=false

# Optional model defaults
KEN_BURNS=true
FRAME_EXPOSER_CASTING_THRESHOLD=5
FRAME_EXPOSER_FORCE_ANCHOR_AFTER_SKIPS=2
FRAME_EXPOSER_FORCE_ANCHOR_MIN_SCORE=4
RENDER_UNEXPOSED_FALLBACK_THRESHOLD=0.4
